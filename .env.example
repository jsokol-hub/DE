# SSH tunnel settings
USE_SSH_TUNNEL=true
SSH_HOST=your-server.example.com
SSH_PORT=22
SSH_USER=your-ssh-user
SSH_KEY_PATH=~/.ssh/id_rsa

# PostgreSQL settings (as seen from the server, not your local machine)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=de_project
DB_USER=postgres
DB_PASSWORD=your-password
